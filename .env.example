# =========================
# Offline Local Mode
# =========================
APP_MODE=offline
PUBLIC_APP_NAME=Sentinelle

# =========================
# MongoDB
# =========================
MONGO_URI=mongodb://mongo:27017/sentinelle

# =========================
# Redis
# =========================
REDIS_URL=redis://redis:6379

# =========================
# MinIO
# =========================
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9000

MINIO_ACCESS_KEY=change_this_minio_user
MINIO_SECRET_KEY=change_this_minio_password

MINIO_BUCKET_RAW=raw-videos
MINIO_BUCKET_FRAMES=flagged-frames
MINIO_BUCKET_REPORTS=incident-reports

# =========================
# Express Server
# =========================
NODE_ENV=development
PORT=5000
JWT_SECRET=change_this_jwt_secret

# =========================
# AI Worker
# =========================
AI_WORKER_URL=http://ai-worker:8000

# =========================
# Local AI Models
# =========================
YOLO_MODEL_PATH=/app/models/yolov8n.pt
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLAVA_MODEL=llava

YOLO_CONFIDENCE_THRESHOLD=0.35
THREAT_OBJECT_CLASSES=gun,pistol,rifle,knife,grenade,bomb,explosive

VOSK_MODEL_PATH=/app/models/vosk-model-small-en-us-0.15

# YOLO_MODEL_PATH=/app/models/weapon-threat-detector.pt
THREAT_OBJECT_CLASSES=gun,pistol,rifle,knife,grenade,bomb,explosive
YOLO_CONFIDENCE_THRESHOLD=0.25